# Supabase credentials for the birthday gift game save/load.
#
# Copy this file to `.env` (or `.env.local`) and fill in the values from:
#   Supabase Dashboard → Project Settings → API
#
# VITE_SUPABASE_URL       → "Project URL" (e.g. https://xxxxxxxx.supabase.co)
# VITE_SUPABASE_ANON_KEY  → "anon public" key (long string starting with eyJ...)
#
# IMPORTANT: never commit the service_role key. It has full DB access.
# Only the anon key is safe to ship to the client bundle.
#
# If either var is missing, src/services/supabaseClient.ts returns null
# and src/services/db.ts transparently falls back to the in-memory mock.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
